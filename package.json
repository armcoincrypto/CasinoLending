{
  "name": "casino-news-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npx tsx scripts/seo/validate-generated-routes.ts && npx tsx scripts/seo/validate-internal-discovery.ts",
    "build": "next build",
    "postbuild": "bash scripts/postbuild-standalone.sh",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint",
    "validate:routes": "npx tsx scripts/seo/validate-generated-routes.ts",
    "validate:internal-discovery": "npx tsx scripts/seo/validate-internal-discovery.ts",
    "validate:live": "bash scripts/seo/validate-live-routes.sh",
    "request-indexing": "node scripts/request-indexing.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
